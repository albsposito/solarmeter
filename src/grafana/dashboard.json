        {
          "datasource": {
            "type": "influxdb",
            "uid": "dfcfr17e5j5kwb"
          },
          "query": "import \"array\"\r\n\r\ntodayArr = from(bucket: \"telemetry\")\r\n  |> range(start: today())\r\n  |> filter(fn: (r) => r._measurement == \"solar_metrics\" and r._field == \"grid_power\")\r\n  |> integral(unit: 1h)\r\n  |> findColumn(fn: (key) => true, column: \"_value\")\r\n\r\navgArr = from(bucket: \"telemetry\")\r\n  |> range(start: -7d, stop: today())\r\n  |> filter(fn: (r) => r._measurement == \"solar_metrics\" and r._field == \"grid_power\")\r\n  |> integral(unit: 1h)\r\n  |> findColumn(fn: (key) => true, column: \"_value\")\r\n\r\ntodayVal = if length(arr: todayArr) > 0 then todayArr[0] / 1000.0 else 0.0\r\navgVal = if length(arr: avgArr) > 0 then avgArr[0] / 1000.0 / 7.0 else 0.0\r\n\r\npctDiff = if avgVal == 0.0 then 0.0 else (todayVal - avgVal) / avgVal * 100.0\r\n\r\nrounded = float(v: int(v: pctDiff * 10.0)) / 10.0\r\n\r\nsign = if rounded > 0.0 then \"+\" else \"\"\r\n\r\narray.from(rows: [{_time: now(), _field: \"pctDiff\", _value: sign + string(v: rounded) + \"%\"}])",
          "refId": "A"
        }
      ],
      "title": "vs 7-Day Average",
      "type": "stat"
    },
